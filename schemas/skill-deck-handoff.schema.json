{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deck-factory.skill-deck-handoff.v1",
  "type": "object",
  "required": [
    "version",
    "sourceSkill",
    "sourceRunId",
    "reportType",
    "subject",
    "audience",
    "objective",
    "preferredStyleId",
    "sections",
    "findings",
    "evidence",
    "citations",
    "requestedCharts",
    "requestedTables",
    "requestedLibrarySlides",
    "assetRefs",
    "sensitivity",
    "openQuestions"
  ],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "sourceSkill": { "type": "string" },
    "sourceRunId": { "type": "string" },
    "reportType": { "type": "string" },
    "subject": { "type": "string" },
    "audience": { "type": "string" },
    "objective": { "type": "string" },
    "preferredStyleId": { "type": "string" },
    "sections": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "findings": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "evidence": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "citations": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "requestedCharts": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "requestedTables": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "requestedLibrarySlides": { "type": "array", "items": { "type": "string" } },
    "assetRefs": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "sensitivity": { "type": "string" },
    "openQuestions": { "type": "array", "items": { "type": "string" } }
  }
}
