{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deck-factory.deck-spec.v1",
  "type": "object",
  "required": ["version", "deck", "template", "style", "librarySlides", "openclaw", "assets", "slides", "constraints"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "deck": {
      "type": "object",
      "required": ["title", "audience", "objective", "tone", "requestedLength", "speakerNotes"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "audience": { "type": "string" },
        "objective": { "type": "string" },
        "tone": { "type": "string" },
        "requestedLength": { "type": "number" },
        "speakerNotes": { "type": "boolean" }
      }
    },
    "template": { "type": "object", "additionalProperties": true },
    "style": { "type": "object", "additionalProperties": true },
    "librarySlides": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "openclaw": {
      "type": "object",
      "required": ["plannerAgent", "reviewerAgent", "polisherAgent", "sessionPrefix", "requiredModelRuntime", "maxRepairAttempts"],
      "additionalProperties": false,
      "properties": {
        "plannerAgent": { "type": "string" },
        "reviewerAgent": { "type": "string" },
        "polisherAgent": { "type": "string" },
        "sessionPrefix": { "type": "string" },
        "requiredModelRuntime": { "type": "string" },
        "maxRepairAttempts": { "type": "number" }
      }
    },
    "assets": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "source", "layout", "purpose", "title", "content", "citations", "constraints"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "source": { "enum": ["generated", "library", "library-pattern"] },
          "layout": { "type": "string" },
          "layoutId": { "type": "string" },
          "librarySlideId": { "type": "string" },
          "purpose": { "type": "string" },
          "selectionReason": { "type": "string" },
          "title": { "type": "string" },
          "actionTitle": { "type": "string" },
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "placeholderId": { "type": "string" },
                "value": { "type": "string" },
                "text": { "type": "string" },
                "items": {
                  "type": "array",
                  "items": {
                    "anyOf": [
                      { "type": "string" },
                      { "type": "object", "additionalProperties": true }
                    ]
                  }
                },
                "fields": { "type": "object", "additionalProperties": { "type": "string" } }
              }
            }
          },
          "assets": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "placeholderId": { "type": "string" },
                "assetId": { "type": "string" },
                "path": { "type": "string" },
                "selectionReason": { "type": "string" }
              }
            }
          },
          "speakerNotes": { "type": "string" },
          "citations": { "type": "array", "items": { "type": "string" } },
          "constraints": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "constraints": { "type": "object", "additionalProperties": true }
  }
}
