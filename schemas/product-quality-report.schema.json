{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deck-factory.product-quality-report.v1",
  "type": "object",
  "required": ["version", "mode", "status", "findings", "metrics"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "mode": { "enum": ["off", "warn", "strict"] },
    "status": { "enum": ["passed", "warning", "failed", "skipped"] },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "category", "message"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "severity": { "enum": ["BLOCKER", "MAJOR", "MINOR", "INFO"] },
          "category": { "type": "string" },
          "slideId": { "type": "string" },
          "slideIndex": { "type": "number" },
          "objectId": { "type": "string" },
          "message": { "type": "string" },
          "suggestedRepairIntent": { "type": "string" }
        }
      }
    },
    "metrics": { "type": "object", "additionalProperties": true }
  }
}
