{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deck-factory.template-compliance-report.v1",
  "type": "object",
  "required": ["version", "status", "styleId", "instructionsPath", "slides", "findings"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "status": { "enum": ["passed", "warning", "failed"] },
    "styleId": { "type": "string" },
    "instructionsPath": { "type": ["string", "null"] },
    "slides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "slideId",
          "layoutId",
          "usedRegisteredLayout",
          "allRequiredPlaceholdersFilled",
          "unknownPlaceholders",
          "missingRequiredPlaceholders",
          "requiredAssetsPresent",
          "requiredCitationsPresent",
          "slideLibrarySourceId",
          "findings"
        ],
        "additionalProperties": false,
        "properties": {
          "slideId": { "type": "string" },
          "layoutId": { "type": "string" },
          "usedRegisteredLayout": { "type": "boolean" },
          "allRequiredPlaceholdersFilled": { "type": "boolean" },
          "unknownPlaceholders": { "type": "array", "items": { "type": "string" } },
          "missingRequiredPlaceholders": { "type": "array", "items": { "type": "string" } },
          "requiredAssetsPresent": { "type": "boolean" },
          "requiredCitationsPresent": { "type": "boolean" },
          "slideLibrarySourceId": { "type": ["string", "null"] },
          "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } }
        }
      }
    },
    "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["id", "severity", "category", "message"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "severity": { "enum": ["BLOCKER", "MAJOR", "MINOR", "INFO"] },
        "category": { "type": "string" },
        "slideId": { "type": "string" },
        "slideIndex": { "type": "number" },
        "objectId": { "type": "string" },
        "message": { "type": "string" },
        "suggestedRepairIntent": { "type": "string" }
      }
    }
  }
}
